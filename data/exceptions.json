    "noun_inflections": {
        "ം_to_ത്ത്": {
            "description": "Nouns ending in ം change to ത്ത് before case markers starting with vowels",
            "examples": {
                "വിദ്യാലയം": {
                    "ിൽ": "വിദ്യാലയത്തിൽ",
                    "ിന്റെ": "വിദ്യാലയത്തിന്റെ",
                    "tokens": ["വിദ്യാലയ", "ത്ത്", "ിൽ"]
                },
                "മാളും": {
                    "ിൽ": "മാളുത്തിൽ",
                    "tokens": ["മാളു", "ത്ത്", "ിൽ"]
                }
            }
        },
        "ം_to_ട്ട്": {
            "description": "Some nouns ending in ം change to ട്ട് before case markers",
            "examples": {
